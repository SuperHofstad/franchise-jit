# Environment Variables for Franchise-JIT

# Toggles (true/false)
ENABLE_RADARR=true
ENABLE_SONARR=true
ENABLE_KOMETA=false

# Radarr Configuration
RADARR_HOST=radarr
RADARR_PORT=7878
RADARR_API_KEY=your_radarr_api_key

# Sonarr Configuration
SONARR_HOST=sonarr
SONARR_PORT=8989
SONARR_API_KEY=your_sonarr_api_key

# Trakt Integration (Optional)
# Create an app at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=your_trakt_client_id

# Kometa Configuration (Optional)
KOMETA_HOST=kometa
KOMETA_PORT=5000

# Advanced Settings
# The Plex/Tautulli username to filter events by.
PLEX_USER=your_plex_username
DELETE_AFTER_WATCHING=false
